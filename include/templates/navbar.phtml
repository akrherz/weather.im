$ar = preg_split('/-/', $THISPAGE);
function get_title($page){
    // Bootstrap 5: caret is handled by dropdown-toggle, icons by Bootstrap Icons
    if (array_key_exists("icon", $page)){
        return sprintf("%s", $page["title"]);
    }
    return sprintf("%s", $page["title"]);
}

foreach($_pages as $idx => $page)
{
            echo sprintf("<li class=\"nav-item dropdown%s\">\n<a class=\"nav-link dropdown-toggle\" href=\"#\" id=\"iemDropdown_%s\" role=\"button\" data-bs-toggle=\"dropdown\" aria-expanded=\"false\">%s</a>\n",
                ($ar[0] == $idx) ? " active" : "", $idx, get_title($page));
            echo "<ul class=\"dropdown-menu\" aria-labelledby=\"iemDropdown_$idx\">\n";
    foreach($page["subs"] as $idx2 => $page2)
    {
             echo sprintf("<li><a%s class=\"dropdown-item\" href=\"%s\">%s</a></li>\n",
                 ($ar[1] == $idx2 && $ar[0] == $idx) ? " class=\"active\"" : "",
                     $page2["url"],  $page2["title"] );
    }
    echo "</ul>\n</li>\n";
}

